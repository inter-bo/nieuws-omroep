{
  "expo": {
    "name": "Nieuws Omroep",
    "slug": "nieuws-omroep",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "nieuwsomroep",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#003366",
      "hideExponentText": true
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "nl.nieuwsomroep.app",
      "buildNumber": "1.0.0",
      "splash": {
        "image": "./assets/images/splash.png",
        "tabletImage": "./assets/images/splash.png",
        "resizeMode": "contain",
        "backgroundColor": "#003366"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "nl.nieuwsomroep.app",
      "permissions": ["INTERNET"],
      "splash": {
        "image": "./assets/images/splash.png",
        "resizeMode": "contain",
        "backgroundColor": "#003366"
      }
    },
    "plugins": [
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "add25f29-dc4a-4c82-a075-95dff96a76fb"
      }
    }
  }
}
